# ===========================================================================
# PlayDesk — Environment Variable Reference
# ===========================================================================
# Copy this file to .env (never commit .env) and fill in your values.
# The docker-compose.yml reads from the environment or falls back to the
# defaults shown here.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Full DSN used by Django's DATABASE_URL setting (via django-environ).
# When running with docker-compose, the hostname is the service name "db".
DATABASE_URL=postgres://playdesk:playdesk@db:5432/playdesk

# Individual variables used directly by the db service in docker-compose.
POSTGRES_USER=playdesk
POSTGRES_PASSWORD=playdesk
POSTGRES_DB=playdesk

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Set to a long random string in production.
SECRET_KEY=django-insecure-change-me-in-production

# Set to false in production.
DEBUG=true

# Comma-separated list of allowed hosts, or * for dev.
ALLOWED_HOSTS=*

# ---------------------------------------------------------------------------
# LLM APIs
# ---------------------------------------------------------------------------
# Provide whichever LLM you use for the agent loop.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding model (OpenAI text-embedding-3-small by default).
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
# Base URL of the Django API as seen by the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
